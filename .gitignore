.DS_Store

# Backup files from in-place edits
*.bak
*.bak.*
*.orig

# Editor and shell temp files
*.swp
*.swo
*~
.idea/
.vscode/
.cursor/

# Local secrets and environment files
.env
.env.*
!.env.example
!.env.*.example

# Keep workspace docs outside repo tracking if a local docs/ folder appears
docs/

# Python/test cache artifacts
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
coverage/

# Dependency and build outputs
node_modules/
dist/
build/

# Local tool state
.serena/
.gemini/
.claude/
.cache/
tmp/

# Local logs
*.log
